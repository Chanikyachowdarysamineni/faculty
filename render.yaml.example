services:
  # ── Backend API ──────────────────────────────────
  - type: web
    name: wlm-server
    env: node
    rootDir: server
    buildCommand: npm ci --omit=dev
    startCommand: npm start
    envVars:
      - key: PORT
        value: 10000
      - key: NODE_ENV
        value: production
      - key: CLIENT_ORIGIN
        value: https://faculty-workload-management-cse-client.onrender.com,https://wlm-client.onrender.com
      - key: MONGO_URI
        sync: false
        # ⚠️  IMPORTANT: Set in Render Dashboard
        # Format: mongodb+srv://username:password@cluster.mongodb.net/database
      - key: JWT_SECRET
        sync: false
        # ⚠️  IMPORTANT: Set in Render Dashboard
        # Use: openssl rand -base64 32
      - key: JWT_EXPIRES_IN
        value: 8h
      - key: BCRYPT_ROUNDS
        value: "10"
      - key: DB_MAX_POOL
        value: "20"
      - key: DB_MIN_POOL
        value: "5"
      - key: AUTH_LOGIN_RATE_LIMIT
        value: "10"
      - key: MAX_FAILED_LOGIN_ATTEMPTS
        value: "5"
      - key: ACCOUNT_LOCK_MINUTES
        value: "15"
      - key: RESET_TOKEN_TTL_MINUTES
        value: "30"
      - key: SMTP_HOST
        value: smtp.gmail.com
      - key: SMTP_PORT
        value: "587"
      - key: SMTP_SECURE
        value: "false"
      - key: SMTP_USER
        sync: false
      - key: SMTP_PASS
        sync: false
      - key: SMTP_FROM
        sync: false
      - key: LOG_LEVEL
        value: info
      - key: ADMIN_ID
        value: admin
      - key: ADMIN_PASSWORD
        sync: false
        # ⚠️  Set in Render Dashboard (strong password)

  # ── Frontend React App ───────────────────────────
  - type: web
    name: wlm-client
    env: static
    rootDir: client
    buildCommand: npm ci && npm run build
    staticPublishPath: build
    envVars:
      - key: REACT_APP_API_URL
        value: https://faculty-workload-management-cse.onrender.com
    routes:
      - type: rewrite
        source: /*
        destination: /index.html

# DEPLOYMENT INSTRUCTIONS:
# 1. Copy this file to render.yaml (local only, not in git)
# 2. Set all "sync: false" variables in Render Dashboard
# 3. DO NOT commit render.yaml with sensitive values
# 4. Use render.yaml.example as reference only
