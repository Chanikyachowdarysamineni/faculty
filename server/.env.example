# .env.example - Environment Configuration Template
# Copy this file to .env and fill in your values
# Never commit .env to git (it contains secrets!)

# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT Authentication ────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=10

# ── Database (MongoDB) ─────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
DB_MAX_POOL=20
DB_MIN_POOL=5

# ── Client Origin (CORS) ───────────────────────────────
CLIENT_ORIGIN=http://localhost:3000

# ── Rate Limiting (Redis-based) ────────────────────────
# REDIS_URL: Optional Redis for distributed rate limiting
# If empty, uses in-memory store (development only)
# 
# Examples:
#   - Local Redis:
#     redis://localhost:6379
#   
#   - Cloud Render addon:
#     redis://default:password@hostname:port
#   
#   - AWS ElastiCache:
#     redis://hostname.cache.amazonaws.com:6379
#   
#   - Azure Cache for Redis:
#     redis://:password@hostname.redis.cache.windows.net:6379
#
REDIS_URL=

# Rate limit maximums (requests per window)
# 
# AUTH_LOGIN_RATE_LIMIT: 1200 per hour (supports 500+ concurrent users)
#   Each user makes ~2-3 login attempts accounting for retries and network issues
#   500 concurrent users * 2.5 attempts = 1250 (with safety margin = 1200)
#   Limit is per IP address (supports load balancers with X-Forwarded-For)
#
AUTH_LOGIN_RATE_LIMIT=1200

# AUTH_PASSWORD_RESET_RATE_LIMIT: 10 per 15 minutes
#   Prevents brute-force password reset enumeration
#
AUTH_PASSWORD_RESET_RATE_LIMIT=10

# API_RATE_LIMIT: 2000 per 15 minutes
#   Supports 500+ concurrent users making API calls
#   Average 4 requests per user per minute = 2000 for 500 users
#
API_RATE_LIMIT=2000

# STRICT_RATE_LIMIT: 150 per hour
#   Tight limit for sensitive POST/PUT/DELETE operations
#   Applied to: faculty modifications, workload changes
#
STRICT_RATE_LIMIT=100

# EXPORT_RATE_LIMIT: 20 per hour
#   Prevents resource exhaustion from bulk data exports
#
EXPORT_RATE_LIMIT=20

# ── Authentication Settings ────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=5         # Lock account after this many failures
ACCOUNT_LOCK_MINUTES=15             # Duration to lock account
RESET_TOKEN_TTL_MINUTES=30          # Password reset link validity

# ── Email (SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password        # NOT your regular password!
SMTP_FROM=noreply@wlm.edu

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=info                      # debug, info, warn, error
LOG_DIR=./logs

# ── Admin Account ──────────────────────────────────────
ADMIN_ID=admin
ADMIN_PASSWORD=change-me-in-production!

# ── Production Recommendations ────────────────────────
# 1. Generate strong JWT_SECRET:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. Use environment-specific values:
#    - Dev: local/test values
#    - Staging: production-like values
#    - Production: secure, validated values
#
# 3. Secrets management:
#    - Use AWS Secrets Manager, Azure Key Vault, etc.
#    - Never commit .env to git
#    - Rotate secrets regularly
#
# 4. Rate limiting:
#    - Always use Redis in production (multiple servers)
#    - Monitor 429 errors
#    - Alert on spikes
#
# 5. Monitoring:
#    - Set LOG_LEVEL=warn in production
#    - Use centralized logging (ELK, CloudWatch, etc.)
#    - Set up alerts for errors
