# ═══════════════════════════════════════════════════════════════
# Faculty Workload Management System - Environment Variables
# ═══════════════════════════════════════════════════════════════
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env to version control (it's in .gitignore)
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Values: development, production
# Production mode hides error details and enforces HTTPS

# ──────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ──────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/wlm
# Format: mongodb+srv://[username]:[password]@[cluster].mongodb.net/[database]
# Or for local: mongodb://localhost:27017/wlm

DB_MAX_POOL=20
# Maximum database connection pool size (default: 20)

DB_MIN_POOL=5
# Minimum database connection pool size (default: 5)

# ──────────────────────────────────────────────────────────────
# JWT & SECURITY
# ──────────────────────────────────────────────────────────────
JWT_SECRET=your-64-character-minimum-random-string-generated-here-securely-please
# CRITICAL: Must be at least 64 characters and truly random
# Generate with: openssl rand -base64 64
# NEVER use predictable values like "secret" or "password"

JWT_EXPIRES_IN=8h
# JWT token expiration time (format: "8h", "7d", etc.)

BCRYPT_ROUNDS=10
# Number of bcrypt salt rounds for password hashing (default: 10)
# Higher = more secure but slower. Recommended: 10-12

# ──────────────────────────────────────────────────────────────
# CORS & ORIGINS
# ──────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000
# Comma-separated list of allowed origins for CORS
# Example: https://app.example.com,https://admin.example.com
# For development: http://localhost:3000

# ──────────────────────────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────────────────────────
AUTH_LOGIN_RATE_LIMIT=10
# Maximum login attempts per IP per 15 minutes (default: 10)

MAX_FAILED_LOGIN_ATTEMPTS=5
# Maximum failed login attempts before account lock (default: 5)

ACCOUNT_LOCK_MINUTES=15
# Duration to lock account after max failed attempts (default: 15)

RESET_TOKEN_TTL_MINUTES=30
# Password reset token expiration time in minutes (default: 30)

# ──────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (SMTP)
# ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
# SMTP server hostname (e.g., smtp.gmail.com, mail.yourcompany.com)

SMTP_PORT=587
# SMTP port (usually 587 for TLS, 465 for SSL)

SMTP_SECURE=false
# Use TLS (true = 465 SSL, false = 587 TLS)

SMTP_USER=your-email@gmail.com
# SMTP authentication username

SMTP_PASS=your-app-password
# SMTP authentication password (use app-specific password for Gmail)

SMTP_FROM=noreply@yourcompany.com
# Sender email address for all system emails

# ──────────────────────────────────────────────────────────────
# LOGGING CONFIGURATION
# ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Log levels: error, warn, info, debug
# Production: use "info" or "warn"
# Development: use "debug"

LOG_DIR=./logs
# Directory where log files are stored (default: ./logs)

# ──────────────────────────────────────────────────────────────
# MONITORING & ERROR TRACKING (Optional)
# ──────────────────────────────────────────────────────────────
SENTRY_DSN=
# Sentry error tracking (optional - leave empty to disable)
# Format: https://[key]@sentry.io/[project-id]

# ──────────────────────────────────────────────────────────────
# FILE UPLOAD CONFIGURATION (Future use)
# ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
# Maximum file upload size in bytes (default: 10MB = 10485760)

UPLOAD_DIR=./uploads
# Directory for file uploads (default: ./uploads)

# ──────────────────────────────────────────────────────────────
# SESSION CONFIGURATION
# ──────────────────────────────────────────────────────────────
SESSION_SECRET=your-session-secret-change-me-in-production
# Secret for session encryption (should be different from JWT_SECRET)

# ──────────────────────────────────────────────────────────────
# ADMIN CREDENTIALS (For initial setup/seeding only)
# ──────────────────────────────────────────────────────────────
ADMIN_ID=admin
# Initial admin employee ID (only used in seed script)

ADMIN_PASSWORD=admin@123
# Initial admin password - CHANGE THIS AFTER FIRST LOGIN
# NEVER USE THIS IN PRODUCTION - use secure password generation

# ══════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ══════════════════════════════════════════════════════════════
# 1. Copy this file: cp .env.example .env
# 2. Fill in all required values (marked above)
# 3. For JWT_SECRET, generate with: openssl rand -base64 64
# 4. For production, use strong passwords and secure SMTP
# 5. Never commit .env to git (it's in .gitignore)
# 6. Use environment variables in deployment platform
#    (Render, Heroku, AWS, etc.) instead of .env files
# ══════════════════════════════════════════════════════════════

